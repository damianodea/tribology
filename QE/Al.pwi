&CONTROL
calculation = 'scf'
restart_mode = 'from_scratch'
prefix = 'SCS-labels'
tprnfor = .true.
!! tstress = .true.
outdir = './OUT/'
disk_io = 'none'
pseudo_dir = '/leonardo_work/IscrC_MeThioML/PSEUDO'
max_seconds = 86000
nstep = 10000
/
 
&SYSTEM    
ibrav = 0
nat = 1
ntyp = 5
ecutwfc = 60
ecutrho = 480
occupations = 'smearing'
smearing = 'gaussian'
degauss = 0.00735
nosym=.true.
vdw_corr = 'dft-d3'
nspin = 2
starting_magnetization(1) = 0.5
starting_magnetization(2) = 0.5
starting_magnetization(3) = 0.5
starting_magnetization(4) = 0.5
starting_magnetization(5) = 0.5
/
 
&ELECTRONS
diagonalization = 'david'
mixing_beta = 0.30
electron_maxstep = 150
mixing_mode = 'local-TF'
mixing_ndim = 16
conv_thr = 1.0d-6
/
 
&IONS
/
 
ATOMIC_SPECIES
Al  26.98   Al.pbe-n-kjpaw_psl.1.0.0.UPF
V   50.942  V.pbe-spnl-rrkjus_psl.1.0.0.UPF
Ti  47.867  Ti.pbe-spn-rrkjus_psl.1.0.0.UPF
Fe  55.845  Fe.pbe-sp-van.UPF
Zn  65.38   Zn.pbe-dnl-kjpaw_psl.1.0.0.UPF
C   12.011  C.pbe-n-kjpaw_psl.1.0.0.UPF
O   15.999  O.pbe-n-kjpaw_psl.1.0.0.UPF
H    1.008  H.pbe-kjpaw_psl.1.0.0.UPF
 
CELL_PARAMETERS angstrom
20.00000   0.000000   0.000000
0.00000  20.300000   0.000000
0.00000   0.000000  20.500000
 
ATOMIC_POSITIONS angstrom
Al    0.0  0.0  0.0