&control
    calculation = 'scf'
    restart_mode = 'from_scratch'
    pseudo_dir = '/leonardo/home/userexternal/apacini0/PSEUDO'
    tprnfor = .true.
    outdir = './OUT/'
    disk_io = 'none'
    max_seconds = 86000
 /
 &system
     ibrav = 0
     nat = 216
     ntyp = 4
     ecutwfc = 50.0
     ecutrho = 400
     occupations = 'smearing'
     smearing = 'gaussian'
     degauss = 0.02
     nspin = 2
     nosym = .true.
     starting_magnetization(1) = 0.1
     vdw_corr = 'DFT-D3'
 /
 &electrons
    diagonalization = 'david'
    electron_maxstep = 200
    mixing_mode = 'local-TF'
    mixing_beta = 0.2
    conv_thr = 1.0d-6
 /

ATOMIC_SPECIES
 Mo  95.95   Mo.pbe-spn-rrkjus_psl.0.2.UPF
 S   32.065  S.pbe-n-rrkjus_psl.0.1.UPF
 O  15.999   O.pbe-n-kjpaw_psl.1.0.0.UPF
 H   1.008   H.pbe-kjpaw_psl.1.0.0.UPF

K_POINTS gamma

